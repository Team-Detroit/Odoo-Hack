generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
  KITCHEN
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderStatus {
  DRAFT
  SENT_TO_KITCHEN
  PREPARING
  COMPLETED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

enum PaymentStatus {
  PENDING
  PAID
}

enum KitchenStatus {
  TO_COOK
  PREPARING
  COMPLETED
}